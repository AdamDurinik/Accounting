<UserControl x:Class="PriceTags.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PriceTags.Views"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:ui="clr-namespace:DevExpress.Mvvm.UI;assembly=DevExpress.Xpf.Core.v24.1"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:enums="clr-namespace:PriceTags.Enums"
             xmlns:viewmodels="clr-namespace:PriceTags.ViewModels"
             xmlns:utils="clr-namespace:PriceTags.Utility"
             xmlns:dx="clr-namespace:DevExpress.Xpf.Core;assembly=DevExpress.Xpf.Core.v24.1"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance viewmodels:MainViewModel}"
             Background="{StaticResource AppBgBrush}">
    <dxmvvm:Interaction.Behaviors>
        <dx:DialogService DialogWindowStartupLocation="CenterOwner">
            <dx:DialogService.ViewTemplate>
                <DataTemplate>
                    <local:HintView />
                </DataTemplate>
            </dx:DialogService.ViewTemplate>
            <dx:DialogService.DialogStyle>
                <Style TargetType="Window">
                    <Setter Property="Height" Value="600" />
                    <Setter Property="Width" Value="400" />
                    <Setter Property="ResizeMode" Value="NoResize" />
                </Style>
            </dx:DialogService.DialogStyle>
        </dx:DialogService>
        <dx:DXMessageBoxService />
    </dxmvvm:Interaction.Behaviors>
    <UserControl.Resources>
        <dxmvvm:ObjectToObjectConverter x:Key="QuantityTypeToStringConverter">
            <ui:MapItem Source="{x:Static enums:QuantityType.WeightInGrams}" Target="g" />
            <ui:MapItem Source="{x:Static enums:QuantityType.WeightInKilograms}" Target="kg" />
            <ui:MapItem Source="{x:Static enums:QuantityType.VolumeInMilliliters}" Target="ml" />
            <ui:MapItem Source="{x:Static enums:QuantityType.VolumeInLiters}" Target="l" />
            <ui:MapItem Source="{x:Static enums:QuantityType.Count}" Target="ks" />
            <ui:MapItem Source="{x:Static enums:QuantityType.Packets}" Target="bal" />
            <ui:MapItem Source="{x:Static enums:QuantityType.Boxes}" Target="box" />
        </dxmvvm:ObjectToObjectConverter>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate x:Key="PriceTagPrintTemplate">
            <Border Grid.Column="1" CornerRadius="4" DataContext="{Binding SelectedPriceTag}" Margin="0,0,0,0"
                    VerticalAlignment="Top" Grid.Row="1" x:Name="PreviewContainer"
                    BorderThickness="{Binding Source={StaticResource AppSettings}, Path=TagBorderThickness}"
                    Height="{Binding Source={StaticResource AppSettings}, Path=TagHeight}"
                    Background="{Binding Source={StaticResource AppSettings}, Path=BackgroundBrush}"
                    BorderBrush="{Binding Source={StaticResource AppSettings}, Path=BorderBrush}">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Top"
                      Width="{Binding Source={StaticResource AppSettings}, Path=TagWidth}"
                      MaxHeight="{Binding Source={StaticResource AppSettings}, Path=InnerGridHeight}"
                      Height="{Binding Source={StaticResource AppSettings}, Path=InnerGridHeight}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding NameCapital, NotifyOnTargetUpdated=True}" FontSize="36" TextAlignment="Left" Margin="10,5,0,0"
                               Height="80" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Top"
                               TextWrapping="Wrap" utils:AutoFontScaler.IsEnabled="True" Background="Transparent"
                               FontFamily="{Binding Source={StaticResource AppSettings}, Path=NameFontFamilyObj}"
                               FontWeight="{Binding Source={StaticResource AppSettings}, Path=NameFontWeightObj}"
                               FontStyle="{Binding Source={StaticResource AppSettings}, Path=NameFontStyleObj}"
                               Foreground="{Binding Source={StaticResource AppSettings}, Path=NameBrush}"/>
                    <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="0" Margin="0,0,0,-10" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0">
                            <TextBlock Text="{Binding Quantity}" FontSize="10" FontWeight="Bold" Background="Transparent"
                                       FontFamily="{Binding Source={StaticResource AppSettings}, Path=TextFontFamilyObj}"
                                       Foreground="{Binding Source={StaticResource AppSettings}, Path=TextBrush}"/>
                            <TextBlock Text="" Background="Transparent"/>
                            <TextBlock Text="{Binding QuantityType, Converter={StaticResource QuantityTypeToStringConverter}}" FontSize="10" FontWeight="Bold" Background="Transparent"
                                       FontFamily="{Binding Source={StaticResource AppSettings}, Path=TextFontFamilyObj}"
                                       Foreground="{Binding Source={StaticResource AppSettings}, Path=TextBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0" Width="150">
                            <TextBlock Text="{Binding PricePerUnit}" FontSize="10" FontWeight="Bold" Background="Transparent"
                                       FontFamily="{Binding Source={StaticResource AppSettings}, Path=TextFontFamilyObj}"
                                       Foreground="{Binding Source={StaticResource AppSettings}, Path=TextBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0"
                                    Visibility="{Binding HasDeposit, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding DepositAmount, StringFormat='{}Záloha {0:N2} €'}" FontSize="10" FontWeight="Bold" Background="Transparent"
                                       FontFamily="{Binding Source={StaticResource AppSettings}, Path=TextFontFamilyObj}"
                                       Foreground="{Binding Source={StaticResource AppSettings}, Path=TextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Margin="0,0,10,-20" VerticalAlignment="Bottom" Background="Transparent" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent">
                            <TextBlock Text="{Binding FullEuroPrice}" FontSize="43" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,0,0,0" Background="Transparent"
                                       FontFamily="{Binding Source={StaticResource AppSettings}, Path=PriceFontFamilyObj}"
                                       Foreground="{Binding Source={StaticResource AppSettings}, Path=PriceBrush}"/>
                            <TextBlock Text="{Binding CentsPrice, StringFormat='.{0:00} €'}" FontSize="25" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,0,0,5" Background="Transparent"
                                       FontFamily="{Binding Source={StaticResource AppSettings}, Path=PriceFontFamilyObj}"
                                       Foreground="{Binding Source={StaticResource AppSettings}, Path=PriceBrush}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{StaticResource HeaderBgBrush}" Padding="14,0" Grid.Row="0">
            <DockPanel Height="52">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Image Source="/Images/LogoOnly.png" Width="26" Height="26" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Cenovky" Foreground="White" FontFamily="Segoe UI Semibold"
                               FontSize="16" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Style="{StaticResource GhostButton}" Command="{Binding UpdateApplicationCommand}"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/updated.png" Width="15" Height="15"/>
                            <TextBlock Text="Nová verzia" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Separator Style="{x:Null}" Width="1" Height="24" Background="#334155" Margin="4,0"/>
                    <Button Style="{StaticResource GhostButton}" Command="{Binding SaveCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/save.png" Width="15" Height="15"/>
                            <TextBlock Text="Uložiť" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GhostButton}" Command="{Binding PrintCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/printer.png" Width="15" Height="15"/>
                            <TextBlock Text="Vytlačiť" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GhostButton}" Command="{Binding HintCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/bulb.png" Width="15" Height="15"/>
                            <TextBlock Text="Nápoveda" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GhostButton}" Command="{Binding DeleteSelectedCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/remove2.png" Width="15" Height="15"/>
                            <TextBlock Text="Zmazať" Margin="6,0,0,0" VerticalAlignment="Center"
                                       Foreground="#FCA5A5"/>
                        </StackPanel>
                    </Button>
                    <Separator Style="{x:Null}" Width="1" Height="24" Background="#334155" Margin="4,0"/>
                    <Button Style="{StaticResource GhostButton}" Command="{Binding SettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/settings.png" Width="15" Height="15"/>
                            <TextBlock Text="Nastavenia" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding PageCountAndTagCount}" Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1" Margin="12,10,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <dxg:GridControl ItemsSource="{Binding PriceTags}" CurrentItem="{Binding SelectedPriceTag, Mode=TwoWay}"
                                 SelectedItems="{Binding SelectedTags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="PriceTagGrid" Loaded="OnLoaded" SelectionChanged="OnSelectionChanged"
                                 AutoGenerateColumns="None" SelectionMode="MultipleRow" PreviewKeyDown="OnPreviewKeyDown" CurrentColumnChanged="OnCurrentColumnChanged">
                    <dxg:GridControl.View>
                        <dxg:TableView AllowPerPixelScrolling="True" AutoWidth="False" ShowGroupPanel="False" ShowCheckBoxSelectorColumn="True"
                                       ShowFilterPanelMode="ShowAlways" NavigationStyle="Cell" AllowEditing="True" AllowColumnMoving="True"
                                       CheckBoxSelectorColumnWidth="35" NewItemRowPosition="Bottom" EditorShowMode="Default"
                                       EnableImmediatePosting="True" AddingNewRow="OnAddingNewRow" ShowingEditor="TableView_ShowingEditor"
                                       HiddenEditor="TableView_HidingEditor" AllowCellMerge="True" />
                    </dxg:GridControl.View>

                    <dxg:GridColumn FieldName="PageNumber" Header="Stránka" AllowCellMerge="True" Width="48" />

                    <dxg:GridColumn FieldName="Name" Header="Názov" Width="*">
                        <dxg:GridColumn.EditSettings>
                            <dxe:ComboBoxEditSettings ItemsSource="{Binding DataContext.Names, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                IsTextEditable="True"
                                ImmediatePopup="True"
                                AutoComplete="True" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="Price" Header="Cena" Width="55" MaxWidth="55" HorizontalHeaderContentAlignment="Right">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings DisplayFormat=" {0:N2} €" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                    <dxg:GridColumn FieldName="Quantity" Header="Množstvo" Width="55" MaxWidth="55" HorizontalHeaderContentAlignment="Right" />

                    <dxg:GridColumn FieldName="QuantityType" Header="Jednotka" Width="60" MaxWidth="60">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:ComboBoxEdit EditValue="{Binding Row.QuantityType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsTextEditable="False"
                                                  BorderBrush="Transparent" BorderThickness="0">
                                    <dxmvvm:Interaction.Behaviors>
                                        <dxmvvm:EnumItemsSourceBehavior EnumType="{x:Type enums:QuantityType}" NameConverter="{StaticResource QuantityTypeToStringConverter}" />
                                    </dxmvvm:Interaction.Behaviors>
                                </dxe:ComboBoxEdit>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="DepositAmount" Header="Záloha" Width="55" MaxWidth="55" HorizontalHeaderContentAlignment="Right">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings DisplayFormat=" {0:N2} €" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>

                    <dxg:GridColumn Width="25" MinWidth="25" MaxWidth="25">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dx:SimpleButton Command="{Binding DataContext.DeleteRowCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding RowData.Row}" BorderThickness="0" Width="23"
                                          BorderBrush="Transparent" Glyph="/Images/remove2.png" Padding="3" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16">
                <StackPanel>
                    <Border CornerRadius="4"
                            DataContext="{Binding SelectedPriceTag}"
                            VerticalAlignment="Top"
                            BorderThickness="{Binding Source={StaticResource AppSettings}, Path=TagBorderThickness}"
                            Height="{Binding Source={StaticResource AppSettings}, Path=TagHeight}"
                            Background="{Binding Source={StaticResource AppSettings}, Path=BackgroundBrush}"
                            BorderBrush="{Binding Source={StaticResource AppSettings}, Path=BorderBrush}">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Top"
                              Width="{Binding Source={StaticResource AppSettings}, Path=TagWidth}"
                              MaxHeight="{Binding Source={StaticResource AppSettings}, Path=InnerGridHeight}"
                              Height="{Binding Source={StaticResource AppSettings}, Path=InnerGridHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding NameCapital, NotifyOnTargetUpdated=True}" FontSize="36" TextAlignment="Left" Margin="10,5,0,0"
                                       Height="80" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Top"
                                       TextWrapping="Wrap" utils:AutoFontScaler.IsEnabled="True" Background="Transparent"
                                       FontFamily="{Binding Source={StaticResource AppSettings}, Path=NameFontFamilyObj}"
                                       FontWeight="{Binding Source={StaticResource AppSettings}, Path=NameFontWeightObj}"
                                       FontStyle="{Binding Source={StaticResource AppSettings}, Path=NameFontStyleObj}"
                                       Foreground="{Binding Source={StaticResource AppSettings}, Path=NameBrush}"/>
                            <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="0" Margin="0,0,0,-10" VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Quantity}" FontSize="10" FontWeight="Bold" Background="Transparent"
                                               FontFamily="{Binding Source={StaticResource AppSettings}, Path=TextFontFamilyObj}"
                                               Foreground="{Binding Source={StaticResource AppSettings}, Path=TextBrush}"/>
                                    <TextBlock Text="" Background="Transparent"/>
                                    <TextBlock Text="{Binding QuantityType, Converter={StaticResource QuantityTypeToStringConverter}}" FontSize="10" FontWeight="Bold" Background="Transparent"
                                               FontFamily="{Binding Source={StaticResource AppSettings}, Path=TextFontFamilyObj}"
                                               Foreground="{Binding Source={StaticResource AppSettings}, Path=TextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0" Width="150">
                                    <TextBlock Text="{Binding PricePerUnit}" FontSize="10" FontWeight="Bold" Background="Transparent"
                                               FontFamily="{Binding Source={StaticResource AppSettings}, Path=TextFontFamilyObj}"
                                               Foreground="{Binding Source={StaticResource AppSettings}, Path=TextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0"
                                            Visibility="{Binding HasDeposit, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding DepositAmount, StringFormat='{}Záloha {0:N2} €'}" FontSize="10" FontWeight="Bold" Background="Transparent"
                                               FontFamily="{Binding Source={StaticResource AppSettings}, Path=TextFontFamilyObj}"
                                               Foreground="{Binding Source={StaticResource AppSettings}, Path=TextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Margin="0,0,10,-20" VerticalAlignment="Bottom" Background="Transparent" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent">
                                    <TextBlock Text="{Binding FullEuroPrice}" FontSize="43" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,0,0,0" Background="Transparent"
                                               FontFamily="{Binding Source={StaticResource AppSettings}, Path=PriceFontFamilyObj}"
                                               Foreground="{Binding Source={StaticResource AppSettings}, Path=PriceBrush}"/>
                                    <TextBlock Text="{Binding CentsPrice, StringFormat='.{0:00} €'}" FontSize="25" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,0,0,5" Background="Transparent"
                                               FontFamily="{Binding Source={StaticResource AppSettings}, Path=PriceFontFamilyObj}"
                                               Foreground="{Binding Source={StaticResource AppSettings}, Path=PriceBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="14,5">
            <DockPanel>
                <TextBlock Text="{Binding CurrentVersion}" Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding UpdateStatusText}" HorizontalAlignment="Center" Margin="10,0,0,0" VerticalAlignment="Center"
                           Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <dxe:ProgressBarEdit Height="20"
                    Minimum="0"
                    Maximum="100"
                    Value="{Binding UpdateProgress}"
                    ContentDisplayMode="Value"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <dxe:ProgressBarEdit.StyleSettings>
                        <dxe:ProgressBarStyleSettings />
                    </dxe:ProgressBarEdit.StyleSettings>
                </dxe:ProgressBarEdit>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
